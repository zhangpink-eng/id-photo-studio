# 环境变量配置示例
# 复制为 .env.local 或 .env.production 使用

# AI 模型 CDN 地址（可选）
# 如果部署到生产环境，建议将模型文件上传到 CDN 以加快首次加载速度
# 留空则使用静态目录 /public/models/
# NEXT_PUBLIC_MODEL_CDN_URL=https://cdn.yourdomain.com/

# ONNX WASM 运行时 CDN 地址（可选）
# 留空则使用静态目录 /public/onnxruntime/
# NEXT_PUBLIC_WASM_CDN_URL=https://cdn.yourdomain.com/
